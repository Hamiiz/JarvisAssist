# ─── Telegram ───────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ─── Google Gemini ───────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Admin IDs ───────────────────────────────────────────────────
# Your Telegram user ID(s) — comma-separated if multiple admins
# Get your ID from: https://t.me/userinfobot
ADMIN_IDS=123456789

# ─── Database ────────────────────────────────────────────────────
# Path to the SQLite database file (auto-created on first run)
DB_PATH=data/bot.db
